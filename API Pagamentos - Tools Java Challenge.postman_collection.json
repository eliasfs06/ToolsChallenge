          "name": "Realizar pagamento - AVISTA",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status HTTP esperado', function () {",
                  "    pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const id = json?.transacao?.id || json?.id;",
                  "if (id) {",
                  "    pm.collectionVariables.set('idTransacao', id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transacao\": {\n    \"cartao\": \"4444********1234\",\n    \"id\": \"100023568900001\",\n    \"descricao\": {\n      \"valor\": \"500.50\",\n      \"dataHora\": \"01/05/2021 18:30:00\",\n      \"estabelecimento\": \"PetShop Mundo cão\"\n    },\n    \"formaPagamento\": {\n      \"tipo\": \"AVISTA\",\n      \"parcelas\": \"1\"\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transacoes/pagar",
